                  <div>
                    <h4 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-2">评测简介</h4>
                    <p class="text-sm text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-line">{airport.desc}</p>
