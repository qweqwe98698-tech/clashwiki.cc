              </div>

              {/* Action Buttons */}
              <div class="flex items-center gap-3 sm:self-center shrink-0">
                <button
                  type="button"
                  class="flex items-center gap-1 text-sm font-semibold text-primary dark:text-blue-400 hover:underline px-3 py-2 rounded-lg hover:bg-gray-50 dark:hover:bg-slate-800/50 transition duration-150 toggle-btn whitespace-nowrap"
