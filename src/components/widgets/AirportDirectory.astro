          >
            🔥 优惠推广中
          </button>
        </div>
      </div>
    </div>

    <!-- Airports Directory List -->
    <div class="space-y-4" id="airports-list">
      {
        airports.map((airport, index) => (
          <div
            class="airport-card border border-gray-200 dark:border-gray-800 rounded-xl bg-white dark:bg-slate-900 shadow-sm transition hover:shadow-md overflow-hidden"
            data-name={airport.name}
            data-tags={airport.tags.join(',')}
            data-desc={airport.desc}
