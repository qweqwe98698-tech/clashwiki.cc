        <span class="block text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500 mb-3">按特性快速过滤</span>
        <div class="flex flex-wrap gap-2" id="filter-buttons">
          <button
            data-filter="all"
            class="filter-btn px-4 py-1.5 rounded-lg text-sm font-medium border border-transparent bg-primary text-white shadow-sm dark:bg-blue-600 transition duration-150"
