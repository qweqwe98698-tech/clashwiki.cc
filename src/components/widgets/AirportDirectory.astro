        请尝试调整您的搜索关键词或选择其他过滤标签进行查询。
      </p>
    </div>
  </div>
</section>

<!-- Frontend Logic for Collapsibles and Live Search / Filter -->
<script>
  const initDirectory = () => {
    const searchInput = document.getElementById('airport-search') as HTMLInputElement;
    if (!searchInput || searchInput.dataset.initialized === 'true') return;
    searchInput.dataset.initialized = 'true';

    // 1. Expand / Collapse details logic
    const cards = document.querySelectorAll('.airport-card');
    
    cards.forEach(card => {
      const trigger = card.querySelector('.toggle-trigger');
      const pane = card.querySelector('.details-pane') as HTMLElement;
      const chevron = card.querySelector('.chevron');
      const toggleBtn = card.querySelector('.toggle-btn span');
      
      if (trigger && pane) {
        trigger.addEventListener('click', (e) => {
          // Prevent expanding if clicked on external link button
          if ((e.target as HTMLElement).closest('a')) return;
          
          const isCollapsed = pane.style.maxHeight === '' || pane.style.maxHeight === '0px';
          
          // Collapse all other panels to keep UI clean (optional accordion effect)
          // For a better comparison page, we allow multiple open, but we toggle this one.
          if (isCollapsed) {
            pane.style.maxHeight = pane.scrollHeight + 'px';
            pane.classList.remove('border-transparent');
            pane.classList.add('border-gray-200', 'dark:border-gray-800');
            if (chevron) chevron.classList.add('rotate-180');
            if (toggleBtn) toggleBtn.textContent = '收起详情';
          } else {
            pane.style.maxHeight = '0px';
            pane.classList.remove('border-gray-200', 'dark:border-gray-800');
            pane.classList.add('border-transparent');
            if (chevron) chevron.classList.remove('rotate-180');
            if (toggleBtn) toggleBtn.textContent = '详情套餐';
          }
        });
      }
    });

    // 2. Search & Filter logic
    const filterButtons = document.querySelectorAll('.filter-btn');
    const matchCountEl = document.getElementById('match-count');
    const emptyState = document.getElementById('empty-state');
    
    let activeFilter = 'all';
    let searchQuery = '';

    const filterAirports = () => {
      let visibleCount = 0;
      
      cards.forEach(cardEl => {
        const card = cardEl as HTMLElement;
        const name = (card.dataset.name || '').toLowerCase();
        const tags = (card.dataset.tags || '').toLowerCase();
        const desc = (card.dataset.desc || '').toLowerCase();
        const hasPromo = card.dataset.hasPromo === 'true';

        // Check if matches query
        const matchesSearch = name.includes(searchQuery) || tags.includes(searchQuery) || desc.includes(searchQuery);

        // Check if matches tag category filter
        let matchesFilter = false;
        if (activeFilter === 'all') {
          matchesFilter = true;
        } else if (activeFilter === 'iplc') {
          matchesFilter = tags.includes('专线') || tags.includes('iplc') || tags.includes('iepl') || desc.includes('专线') || desc.includes('iplc') || desc.includes('iepl');
        } else if (activeFilter === 'cheap') {
          matchesFilter = tags.includes('性价比') || tags.includes('便宜') || tags.includes('预算') || tags.includes('低价') || desc.includes('性价比') || desc.includes('便宜') || desc.includes('低预算');
        } else if (activeFilter === 'media') {
          matchesFilter = tags.includes('流媒体') || tags.includes('netflix') || tags.includes('解锁') || tags.includes('视频') || tags.includes('日常娱乐') || desc.includes('流媒体') || desc.includes('netflix') || desc.includes('视频');
        } else if (activeFilter === 'ai') {
          matchesFilter = tags.includes('ai') || tags.includes('chatgpt') || tags.includes('claude') || tags.includes('工具') || tags.includes('办公') || desc.includes('ai') || desc.includes('chatgpt') || desc.includes('openai');
        } else if (activeFilter === 'newbie') {
          matchesFilter = tags.includes('新手') || tags.includes('友好') || tags.includes('简单') || tags.includes('配置') || desc.includes('新手') || desc.includes('新手友好') || desc.includes('入门');
        } else if (activeFilter === 'promo') {
          matchesFilter = hasPromo;
        }

        if (matchesSearch && matchesFilter) {
          card.classList.remove('hidden');
          visibleCount++;
        } else {
          card.classList.add('hidden');
        }
      });

      // Update counters & empty state
      if (matchCountEl) matchCountEl.textContent = visibleCount.toString();
      if (emptyState) {
        if (visibleCount === 0) {
          emptyState.classList.remove('hidden');
        } else {
          emptyState.classList.add('hidden');
        }
      }
    };

    // Listen to search changes
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        searchQuery = (e.target as HTMLInputElement).value.trim().toLowerCase();
        filterAirports();
      });
    }

    // Listen to filter buttons
    filterButtons.forEach(btnEl => {
      const btn = btnEl as HTMLButtonElement;
      btn.addEventListener('click', () => {
        // Remove active class from all buttons
        filterButtons.forEach(b => {
          b.classList.remove('bg-primary', 'text-white', 'dark:bg-blue-600', 'shadow-sm', 'border-transparent');
          b.classList.add('border-gray-200', 'dark:border-gray-700', 'text-gray-700', 'dark:text-gray-300', 'hover:bg-gray-50', 'dark:hover:bg-slate-800');
        });

        // Add active class to clicked button
        btn.classList.remove('border-gray-200', 'dark:border-gray-700', 'text-gray-700', 'dark:text-gray-300', 'hover:bg-gray-50', 'dark:hover:bg-slate-800');
        btn.classList.add('bg-primary', 'text-white', 'dark:bg-blue-600', 'shadow-sm', 'border-transparent');

        activeFilter = btn.dataset.filter || 'all';
        filterAirports();
      });
    });
  };

  // Register events
  document.addEventListener('DOMContentLoaded', initDirectory);
  document.addEventListener('astro:page-load', initDirectory);
</script>
