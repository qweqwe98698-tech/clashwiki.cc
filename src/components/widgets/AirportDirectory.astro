---
import airportsData from '~/data/airports.json';

// Define TS interface for validation
interface Plan {
  name: string;
  price: string;
  traffic: string;
  note: string;
}

interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface Airport {
  name: string;
  tags: string[];
  desc: string;
  features: Feature[];
  plans: Plan[];
  affLink: string;
  slug?: string;
}

const charMap: Record<string, string> = {
  '光':'guang','速':'su','云':'yun','飞':'fei','猫':'mao','唯':'wei','兔':'tu','全':'quan','球':'qiu','二':'er','极':'ji','连':'lian',
  '年':'nian','梯':'ti','可':'ke','信':'xin','星':'xing','岛':'dao','梦':'meng','一':'yi','翻':'fan','宇':'yu','宙':'zhou','边':'bian',
  '缘':'yuan','节':'jie','点':'dian','快':'kuai','狸':'li','狗':'gou','界':'jie','大':'da','象':'xiang','网':'wang','络':'luo','加':'jia',
  '悠':'you','鹿':'lu','语':'yu','龙':'long','游':'you','乐':'le','园':'yuan','库':'ku','洛':'luo','米':'mi','次':'ci','元':'yuan',
  '青':'qing','奶':'nai','昔':'xi','闪':'shan','狐':'hu','夜':'ye','煞':'sha','配套':'peitao','贝':'bei','守':'shou','候':'hou','肥':'fei','鸟':'niao',
  '扬':'yang','帆':'fan','五':'wu','树':'shu','猪':'zhu','酷':'ku','尔':'er','湾':'wan','养':'yang','鸡':'ji','场':'chang','小':'xiao','跑':'pao',
  '疾':'ji','风':'feng','精':'jing','灵':'ling','学':'xue','院':'yuan','旋':'xuan','机':'ji','奈':'nai','最':'zui','萌':'meng',
  '蛋':'dan','挞':'ta','八':'ba','戒':'jie','魔':'mo','老':'lao','临':'lin','芝':'zhi','士':'shi','蓝':'lan',
  '银':'yin','河':'he','太':'tai','空':'kong','超':'chao','能':'neng','水':'shui','蜜':'mi','桃':'tao','科':'ke','客':'ke','糖':'tang',
  '果':'guo','泡':'pao','天':'tian','之':'zhi','城':'cheng','翼':'yi','行':'xing','者':'zhe'
};

function getSlug(name: string): string {
  // eslint-disable-next-line no-useless-escape
  let cleaned = name.toLowerCase().replace(/[^a-z0-9\u4e00-\u9fa5\s-\/]/g, '').trim();
  // eslint-disable-next-line no-useless-escape
  cleaned = cleaned.replace(/[\s\/_-]+/g, '-');
  
  let slug = '';
  for (let i = 0; i < cleaned.length; i++) {
    const char = cleaned[i];
    if (charMap[char]) {
      slug += (slug.endsWith('-') || slug === '' ? '' : '-') + charMap[char];
    } else if (/[a-z0-9-]/.test(char)) {
      slug += char;
    }
  }
  
  if (!slug || slug === '-') {
    slug = 'airport-' + Math.random().toString(36).substring(2, 7);
  }
  
  return slug.replace(/-+/g, '-').replace(/^-|-$/g, '') + '-review';
}

const airports = (airportsData as Airport[]).map(airport => {
  return {
    ...airport,
    slug: getSlug(airport.name)
  };
});

// Standardize tags matching function helper for frontend categorization
// We will assign colors to different categories of tags
const getTagColorClass = (tag: string) => {
  const t = tag.toLowerCase();
  if (t.includes('专线') || t.includes('iplc') || t.includes('iepl')) {
    return 'bg-blue-50 text-blue-700 border-blue-200 dark:bg-blue-900/30 dark:text-blue-300 dark:border-blue-800';
  }
  if (t.includes('性价比') || t.includes('便宜') || t.includes('预算') || t.includes('折扣')) {
    return 'bg-green-50 text-green-700 border-green-200 dark:bg-green-900/30 dark:text-green-300 dark:border-green-800';
  }
  if (t.includes('流媒体') || t.includes('netflix') || t.includes('解锁') || t.includes('视频') || t.includes('娱乐')) {
    return 'bg-purple-50 text-purple-700 border-purple-200 dark:bg-purple-900/30 dark:text-purple-300 dark:border-purple-800';
  }
  if (t.includes('ai') || t.includes('chatgpt') || t.includes('claude') || t.includes('办公') || t.includes('工具')) {
    return 'bg-orange-50 text-orange-700 border-orange-200 dark:bg-orange-900/30 dark:text-orange-300 dark:border-orange-800';
  }
  if (t.includes('新手') || t.includes('友好') || t.includes('简单') || t.includes('配置')) {
    return 'bg-teal-50 text-teal-700 border-teal-200 dark:bg-teal-900/30 dark:text-teal-300 dark:border-teal-800';
  }
  return 'bg-gray-50 text-gray-700 border-gray-200 dark:bg-gray-800/50 dark:text-gray-300 dark:border-gray-700';
};
---

<section class="relative not-prose py-12 md:py-16">
  <!-- Background decoration -->
  <div class="absolute inset-0 bg-blue-50/50 dark:bg-slate-900/30 pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Search & Filter Controls -->
    <div class="mb-8 p-6 bg-white dark:bg-slate-900 border border-gray-200 dark:border-gray-800 rounded-2xl shadow-sm backdrop-blur">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <!-- Search input -->
        <div class="md:col-span-2 relative">
          <input
            type="text"
            id="airport-search"
            placeholder="搜索机场名称，例如：光速云、WgetCloud..."
