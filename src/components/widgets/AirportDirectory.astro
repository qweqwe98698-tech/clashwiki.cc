                  >
                    官网注册 ↗
                  </a>
                ) : (
                  <a
                    href="https://qwerty.gsyaff.com/#/?code=keqgvT5Y"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center px-4 py-2 rounded-lg text-sm font-semibold border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-slate-800 transition duration-150 whitespace-nowrap"
                  >
                    极速注册
                  </a>
                )}
              </div>
            </div>

            {/* Expandable Details Content Container */}
            <div class="details-pane max-h-0 overflow-hidden transition-all duration-300 ease-in-out border-t border-transparent dark:border-transparent">
              <div class="p-6 bg-gray-50/50 dark:bg-slate-900/50 space-y-6">
                {/* Detailed Introduction */}
